# ═══════════════════════════════════════════
# ContentPro — Environment Variables
# ═══════════════════════════════════════════

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Encryption ──
# Must be EXACTLY 32 characters for AES-256
ENCRYPTION_KEY=your-32-character-encryption-key!

# ── Telegram (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Admin Setup ──
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=your-secure-password

# ── App ──
NEXT_PUBLIC_APP_NAME=ContentPro
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cloudflare Worker (optional — for production proxy) ──
# If not set, API routes decrypt keys directly (development mode)
NEXT_PUBLIC_WORKER_URL=